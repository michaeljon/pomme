{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Assembler",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/ConsoleTools/Asm6502/bin/Debug/net10.0/Asm6502.dll",
      "args": [],
      "cwd": "${workspaceFolder}/ConsoleTools/Asm6502",
      "console": "internalConsole",
      "stopAtEntry": false,
      "requireExactSource": false
    },
    {
      "name": "Disassembler",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/ConsoleTools/Dasm6502/bin/Debug/net10.0/Dasm6502.dll",
      "args": [
        "--input",
        "${workspaceFolder}/ConsoleTools/Emu6502/roms/apple2e.rom",
        "--output",
        "-"
      ],
      "cwd": "${workspaceFolder}/ConsoleTools/Dasm6502",
      "console": "internalConsole",
      "stopAtEntry": false,
      "requireExactSource": false
    },
    {
      "name": "Simulator",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/ConsoleTools/Sim6502/bin/Debug/net10.0/Sim6502.dll",
      "args": ["--input", "tests/simple.S", "--origin", "32768"],
      "cwd": "${workspaceFolder}/ConsoleTools/Sim6502",
      "console": "internalConsole",
      "stopAtEntry": false,
      "requireExactSource": false
    },
